PORT=3000
VITE_PORT=5173
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: use a custom path for the SQLite file.
# DATABASE_URL=./data/homepage-analyzer.db
# Optional if you want to point at a non-default Anthropic-compatible endpoint.
# ANTHROPIC_BASE_URL=
# Optional if you are running the frontend against a separately hosted API.
# VITE_API_BASE_URL=http://localhost:3000
# Optional if you want the Vite dev proxy to use a non-default API host.
# VITE_API_PROXY_TARGET=http://localhost:3000
# Optional if you build the frontend somewhere else before starting the API server.
# WEB_DIST_DIR=
# Optional if you want to serve the app from a subpath.
# BASE_PATH=/
